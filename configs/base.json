{
  "project": {
    "name": "sta561-pest-pipeline",
    "root": "."
  },
  "inputs": {
    "kitchen_photo": "data/inputs/kitchen.jpg",
    "kitchen_photo_dir": "data/raw/kitchen/images",
    "kitchen_manifest": "data/raw/kitchen/metadata/manifest.csv",
    "layout_spec": "data/intermediate/layout/layout.json",
    "layout_diagnostics": "artifacts/layout/layout_diagnostics.json",
    "layout_preview": "artifacts/layout/layout_preview.svg"
  },
  "render": {
    "backend": "blender",
    "blender_executable": "blender",
    "blender_script": "src/prob_ml/blender/render_scene.py",
    "execute": false,
    "render_device": "CPU",
    "compute_backend": "AUTO",
    "photo_background": true,
    "pest_asset_style": "hybrid",
    "asset_root": "assets/pests",
    "batch_output_dir": "artifacts/batch_render",
    "batch_limit": 5,
    "batch_enabled_only": true,
    "scene_seed": 42,
    "fps": 30,
    "seconds": 30,
    "resolution_width": 1280,
    "resolution_height": 720,
    "samples": 64,
    "pest_types": ["mouse", "rat", "cockroach"],
    "mux_video": true,
    "ffmpeg_executable": "ffmpeg",
    "video_crf": 20
  },
  "dataset": {
    "frames_dir": "artifacts/render/frames",
    "annotations_raw": "artifacts/render/annotations.json",
    "coco_annotations": "artifacts/dataset/coco_annotations.json",
    "video_output": "artifacts/render/video.mp4",
    "frame_stride": 1
  },
  "training": {
    "model_name": "vit",
    "detector_model": "vit",
    "output_dir": "artifacts/models/detector",
    "train_annotations": "artifacts/dataset/coco_train.json",
    "val_annotations": "artifacts/dataset/coco_val.json",
    "neg_test_annotations": "artifacts/dataset/coco_neg_test.json",
    "epochs": 6,
    "batch_size": 2,
    "learning_rate": 2e-5,
    "weight_decay": 1e-4,
    "pretrained": true,
    "checkpoint_interval": 3,
    "transformer_image_size": 640,
    "augmentation": {
      "horizontal_flip_probability": 0.5,
      "color_jitter": {
        "brightness": 0.2,
        "contrast": 0.2,
        "saturation": 0.1
      }
    },
    "val_split": 0.2,
    "device": "auto",
    "num_workers": 0,
    "score_threshold": 0.3,
    "iou_threshold": 0.5,
    "threshold_sweep": [0.3, 0.5, 0.7]
  },
  "yolo": {
    "data_yaml": "artifacts/dataset/yolo/data.yaml",
    "output_dir": "artifacts/models/yolo",
    "model": "yolov8n.pt",
    "epochs": 20,
    "imgsz": 640,
    "batch": 8,
    "workers": 4,
    "device": "auto",
    "name": "pest-yolo"
  },
  "sanity": {
    "output_dir": "artifacts/reports",
    "max_overlay_images": 12
  },
  "evaluation": {
    "output_dir": "artifacts/reports/evaluation",
    "checkpoint": "artifacts/models/detector/detector.pt",
    "thresholds": [0.3, 0.5, 0.7],
    "iou_threshold": 0.5,
    "max_failure_examples": 12
  },
  "inference": {
    "input_image": "data/inputs/kitchen.jpg",
    "output_image": "artifacts/infer/infer_result.jpg",
    "checkpoint": "artifacts/models/detector/detector.pt",
    "predictions_json": "artifacts/infer/predictions.json",
    "threshold": 0.6,
    "window_sizes": [64, 96, 128, 160, 224],
    "stride_ratio": 0.25
  },
  "dcc": {
    "profile": "duke",
    "partition": "scavenger-h200",
    "account": "scavenger-h200",
    "time": "04:00:00",
    "gpus": 1,
    "cpus_per_task": 8,
    "memory": "32G",
    "job_script_dir": "jobs",
    "log_dir": "logs/dcc"
  },
  "pipeline": {
    "stages": ["render-batch", "convert", "sanity-check", "train", "evaluate"]
  }
}
